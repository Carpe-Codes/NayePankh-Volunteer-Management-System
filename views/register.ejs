<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register</title>
</head>
<body>
    <form action="/auth/register" method="post">

        <input
            type="text"
            name="name"
            placeholder="Name"
            required
        >
        <small style="color:gray;">
            Min 3 charecters
        </small>

        <br><br>

        <input
            type="email"
            name="email"
            placeholder="Email"
            required
        >
        <small style="color:gray;">
            Valid email required 
        </small>

        <br><br>

        <input
            type="password"
            name="password"
            placeholder="Password"
            required
        >
        <small style="color:gray;">
            Min 5 charecters
        </small>

        <br><br>

        <input
            type="text"
            name="phone"
            placeholder="Phone"
            required
        >
        <small style="color:gray;">
                Exactly 10 digits required
        </small>

        <br><br>

        <input
            type="text"
            name="college"
            placeholder="College"
            required
        >

        <br><br>

        <input
            type="text"
            name="skills"
            placeholder="Skills"
            required
        >

        <br><br>

        <button type="submit">
            Register
        </button>

    </form>
</body>
</html>